# ===============================

# GROQ LLM CONFIGURATION

# ===============================

GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=llama3-70b-8192

# ===============================

# LINKEDIN API CONFIGURATION

# ===============================

# OAuth Access Token (short-lived)

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# OAuth App Credentials

LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# LinkedIn User URN (format: urn:li:person:xxxx)

LINKEDIN_PERSON_ID=urn:li:person:your_person_id_here

# ===============================

# LANGSMITH CONFIGURATION

# ===============================

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_langsmith_project_name_here
